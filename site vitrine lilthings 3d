</div>

<script>
  let cartItems = 0;
  let cartTotal = 0;

  function addToCart(name, price) {
    cartItems++;
    cartTotal += price;
    document.getElementById('cartCount').textContent = cartItems;
    showNotif(`"${name}" ajouté au panier · ${cartTotal.toFixed(2)} €`);
  }

  function toggleCart() {
    showNotif(`${cartItems} article(s) · Total : ${cartTotal.toFixed(2)} €`);
  }

  function showNotif(msg) {
    const n = document.getElementById('notif');
    document.getElementById('notifText').textContent = msg;
    n.classList.add('show');
    setTimeout(() => n.classList.remove('show'), 3000);
  }

  function filterProducts(cat, btn) {
    document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
    btn.classList.add('active');
    document.querySelectorAll('.product-card').forEach(card => {
      if (cat === 'all' || card.dataset.cat === cat) {
        card.style.display = '';
        card.style.animation = 'none';
        requestAnimationFrame(() => {
          card.style.animation = '';
        });
      } else {
        card.style.display = 'none';
      }
    });
  }

  function submitForm() {
    showNotif('Demande envoyée ! Réponse sous 24h 🎉');
  }

  // Smooth parallax scroll for hero glow
  window.addEventListener('scroll', () => {
    const glow = document.querySelector('.hero-glow');
    if (glow) {
      glow.style.transform = `translateY(${window.scrollY * 0.3}px)`;
    }
  });
</script>
